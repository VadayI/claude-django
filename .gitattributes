# Force LF line endings across the repo, regardless of OS.
# Rationale: project lives on Windows + WSL2 and on a Debian VPS; bind-mounts
# between Windows and WSL2 routinely flip CRLF<->LF and produce phantom diffs
# (whole-file rewrites with no content change). LF-only kills the noise.

# Default: auto-detect text vs binary; commit and check out as LF.
* text=auto eol=lf

# Shell scripts MUST be LF (CRLF breaks the shebang on Linux).
*.sh        text eol=lf
# Python scripts and source — LF (matches the runtime environment).
*.py        text eol=lf
# YAML / TOML / JSON / Markdown / Dockerfile — LF (config + docs).
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
Dockerfile  text eol=lf
*.Dockerfile text eol=lf
.env.example text eol=lf

# Binary assets — never normalize, never diff.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
