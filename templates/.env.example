# Copy this file to `.env` at the project root and fill in real values.
# `.env` is gitignored — never commit it. The example is committed so a new
# clone knows which keys to expect.

# --- Django ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- PostgreSQL (consumed by docker-compose.yml) ---
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
DATABASE_URL=postgres://app:app@db:5432/app

# --- MCP servers (.mcp.json) ---
# GitHub MCP — PR data, reviews, repo metadata. Create a fine-grained PAT at
# https://github.com/settings/tokens (scopes: repo, read:org).
GITHUB_PERSONAL_ACCESS_TOKEN=
# Context7 MCP — up-to-date library docs (Django, DRF). Get a key at
# https://context7.com/
CONTEXT7_API_KEY=

# --- Staging (VPS deploy via the `devops` agent) ---
# Used by docker-compose.staging.yml; leave blank for local-only work.
STAGING_HOST=
STAGING_USER=
STAGING_SSH_KEY_PATH=

# Last reviewed/updated: 2026-05-30
